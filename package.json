{
  "name": "bubblebuddy-workspace",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=25.9.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@google/genai",
      "better-sqlite3",
      "cpu-features",
      "koffi",
      "msgpackr-extract",
      "protobufjs",
      "ssh2"
    ]
  },
  "scripts": {
    "check": "pnpm -r run check",
    "dev": "pnpm --filter bubblebuddy run dev",
    "start": "pnpm --filter bubblebuddy run start"
  }
}
