{
  "name": "bubblebuddy",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "bun run fmt:check && bun run lint && bun run typecheck && bun run test",
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "test": "bun test",
    "lint": "oxlint src test",
    "lint:fix": "oxlint src test --fix",
    "fmt": "oxfmt src test",
    "fmt:check": "oxfmt src test --check",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@effect/platform-bun": "^4.0.0-beta.56",
    "@mariozechner/pi-ai": "0.69.0",
    "@mariozechner/pi-coding-agent": "0.69.0",
    "discord.js": "^14.25.1",
    "effect": "^4.0.0-beta.56",
    "typebox": "^1.1.31"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "typescript": "^6.0.3"
  }
}
