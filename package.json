{
  "name": "bubblebuddy",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=25.9.0"
  },
  "scripts": {
    "check": "bun run fmt:check && bun run lint && bun run typecheck && bun run test",
    "dev": "node --env-file-if-exists=.env --watch src/index.ts",
    "start": "node --env-file-if-exists=.env src/index.ts",
    "test": "bun test",
    "lint": "oxlint src test",
    "lint:fix": "oxlint src test --fix",
    "fmt": "oxfmt src test",
    "fmt:check": "oxfmt src test --check",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@earendil-works/gondolin": "^0.8.0",
    "@effect/platform-node": "4.0.0-beta.57",
    "@mariozechner/pi-ai": "0.70.2",
    "@mariozechner/pi-coding-agent": "0.70.2",
    "discord.js": "^14.25.1",
    "effect": "^4.0.0-beta.57",
    "typebox": "^1.1.33"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "typescript": "^6.0.3"
  }
}
