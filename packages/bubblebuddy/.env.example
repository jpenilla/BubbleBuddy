# Required
DISCORD_TOKEN=your-discord-bot-token

# Optional: Override the BubbleBuddy data directory.
# Defaults per platform:
#   macOS:  ~/Library/Application Support/BubbleBuddy
#   Windows: %APPDATA%/BubbleBuddy
#   Linux:   ~/.local/share/bubblebuddy
# BUBBLEBUDDY_HOME=/path/to/data

# Optional: Parallel API key (enables higher rate limits; free tier works without a key)
# PARALLEL_API_KEY=your-parallel-api-key

# Optional: Override the image used for Gondolin VMs
# GONDOLIN_DEFAULT_IMAGE=agent-x86_64:latest
