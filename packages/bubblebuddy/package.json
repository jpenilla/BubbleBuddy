{
  "name": "bubblebuddy",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "pnpm run fmt:check && pnpm run lint && pnpm run typecheck && pnpm run test",
    "dev": "node --env-file-if-exists=.env --watch src/index.ts",
    "start": "node --env-file-if-exists=.env src/index.ts",
    "test": "vitest run",
    "lint": "oxlint src test",
    "lint:fix": "oxlint src test --fix",
    "fmt": "oxfmt src test",
    "fmt:check": "oxfmt src test --check",
    "typecheck": "tsgo -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "catalog:",
    "@earendil-works/pi-ai": "catalog:",
    "@earendil-works/pi-coding-agent": "catalog:",
    "@effect/platform-node": "catalog:",
    "@effect/sql-sqlite-node": "catalog:",
    "@modelcontextprotocol/sdk": "catalog:",
    "discord.js": "catalog:",
    "effect": "catalog:",
    "incus-api": "workspace:*",
    "typebox": "catalog:"
  },
  "devDependencies": {
    "@effect/tsgo": "catalog:",
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
