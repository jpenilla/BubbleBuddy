{
  "name": "incus-api",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "check": "pnpm run fmt:check && pnpm run lint && pnpm run typecheck && pnpm run test",
    "test": "vitest run --passWithNoTests",
    "lint": "oxlint src test",
    "lint:fix": "oxlint src test --fix",
    "fmt": "oxfmt src test",
    "fmt:check": "oxfmt src test --check",
    "typecheck": "tsgo -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@effect/platform-node": "catalog:",
    "effect": "catalog:"
  },
  "devDependencies": {
    "@effect/tsgo": "catalog:",
    "@effect/vitest": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
