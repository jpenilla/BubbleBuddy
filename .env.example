# Required
DISCORD_TOKEN=your-discord-bot-token
PI_PROVIDER=openai
PI_MODEL=gpt-5.4-mini
STORAGE_DIRECTORY=storage

# Optional: committed profile preset controlling personality/behavior.
BOT_PROFILE_FILE=profiles/friendly.md

# Optional: local Discord runtime context template.
# Copy discord-context.md.example to discord-context.md to get started.
DISCORD_CONTEXT_TEMPLATE_FILE=discord-context.md

# Future capability gate. Must remain false for now.
ENABLE_AGENTIC_WORKSPACE=false

# Optional: one of off, minimal, low, medium, high, xhigh
PI_THINKING_LEVEL=minimal

# Optional: typing indicator refresh interval in milliseconds
DISCORD_TYPING_INTERVAL_MS=8000
